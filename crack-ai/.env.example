# ─── Database ────────────────────────────────────────────────────────────────────
# Copy from NestJS backend .env (DATABASE_URL must be the same)
DATABASE_URL=postgresql://postgres:PASSWORD@host:PORT/railway

# ─── JWT ─────────────────────────────────────────────────────────────────────────
# Must be EXACTLY THE SAME as JWT_SECRET in NestJS backend!
JWT_SECRET=super-secret-dont-share-123
JWT_ALGORITHM=HS256

# ─── LLM Provider (OpenAI-compatible) ────────────────────────────────────────────
# API Key for LLM service. Currently uses DeepSeek by default.
# Get a DeepSeek API key at: https://platform.deepseek.com/api_keys
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ─── Server ───────────────────────────────────────────────────────────────────────
PORT=8001
# CORS: Allowed frontend URLs to access AI (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Security ────────────────────────────────────────────────────────────────────
# Hard limit: AI cannot request data exceeding this number (prevents OOM)
MAX_QUERY_LIMIT=50
# Max input length for AI queries (character limit)
MAX_QUERY_LENGTH=2000

# ─── Internal API Key ────────────────────────────────────────────────────────────
# ⚠️  WAJIB: Ubah nilai ini! Tidak ada default value untuk keamanan.
# Digunakan oleh NestJS backend untuk autentikasi backend-to-AI.
# Harus match dengan AI_INTERNAL_API_KEY di NestJS backend .env
#
# Generate key yang aman dengan perintah:
#   openssl rand -hex 32
#
# Contoh hasil: 7f3b8e2a1c9d4f6e8a0b3c5d7e9f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f
# INTERNAL_API_KEY=

# ─── NestJS Backend (for HTTP data fetching) ─────────────────────────────────────
# Backend API URL where the NestJS app is running
# BACKEND_URL=http://localhost:8000
# Internal API key to authenticate with NestJS AiDataController
# Must match AI_INTERNAL_API_KEY in NestJS .env
# BACKEND_INTERNAL_API_KEY=
