# ============================================================
# .env.example — Template environment variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control!
# ============================================================

# --- DATABASE ---
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/inventory_db?schema=public"

# --- JWT ---
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS"

# --- SERVER ---
PORT=3000

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3001"

# --- SEED (used by prisma/seed.ts only) ---
DEFAULT_ADMIN_PASSWORD="REPLACE_WITH_SECURE_ADMIN_PASSWORD"
DEFAULT_STAFF_PASSWORD="REPLACE_WITH_SECURE_STAFF_PASSWORD"
