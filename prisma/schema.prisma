datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════════════════════════════════════
// PLATFORM ADMIN — Super Admin (developer/pemilik platform)
// ═══════════════════════════════════════════════════════════════════════

model PlatformAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@map("platform_admins")
}

// ═══════════════════════════════════════════════════════════════════════
// TENANT (Toko) — Multi-tenant core
// ═══════════════════════════════════════════════════════════════════════

model Tenant {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  aiApiKey     String?  // API key untuk AI service (billing per toko)
  aiTokens     Int      @default(0)  // Total token AI untuk toko ini
  aiTokensUsed Int      @default(0)  // Token AI yang sudah terpakai
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  members      TenantMember[]
  products     Product[]
  categories   Category[]
  suppliers    Supplier[]
  users        TenantUser[]
  salesOrders  SalesOrder[]
  purchaseOrders PurchaseOrder[]
  stockTransactions StockTransaction[]
  returns           SalesReturn[]
  activityLogs      ActivityLog[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════════════════════════════
// TENANT USER — User khusus untuk satu toko (terisolasi per tenant)
// ═══════════════════════════════════════════════════════════════════════

enum TenantRole {
  ADMIN
  STAFF
}

model TenantUser {
  id                  String   @id @default(uuid())
  username            String
  passwordHash        String
  role                TenantRole @default(STAFF)
  displayName         String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime @default(now())
  deletedAt           DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  transactions   StockTransaction[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  returns        SalesReturn[]
  activityLogs   ActivityLog[]
  refreshTokens  RefreshToken[]

  @@unique([tenantId, username])
  @@index([username, deletedAt])
  @@index([tenantId, role])
  @@map("tenant_users")
}

// ═══════════════════════════════════════════════════════════════════════
// PLATFORM USER — User global untuk login ke platform (Google/Email)
// ═══════════════════════════════════════════════════════════════════════

model PlatformUser {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String?
  googleId       String?  @unique
  passwordHash   String?
  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  tenantMemberships TenantMember[]

  @@map("platform_users")
}

// ═══════════════════════════════════════════════════════════════════════
// TENANT MEMBER — Relasi PlatformUser ke Tenant (siapa punya toko apa)
// ═══════════════════════════════════════════════════════════════════════

model TenantMember {
  id         String   @id @default(uuid())
  role       String   @default("OWNER") // OWNER, MEMBER
  createdAt  DateTime @default(now())

  platformUserId String
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([platformUserId, tenantId])
  @@map("tenant_members")
}

// ═══════════════════════════════════════════════════════════════════════
// PRODUCT — Sekarang terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

model Product {
  id            String    @id @default(uuid())
  sku           String
  name          String
  description   String?   @db.Text
  imageUrl      String?
  price         Decimal   @db.Decimal(12, 2)
  averageCost   Decimal   @default(0) @db.Decimal(12, 2)
  stockQuantity Int       @default(0)
  reorderLevel  Int       @default(10)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  transactions       StockTransaction[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku])
  @@index([sku])
  @@index([name])
  @@index([stockQuantity, reorderLevel, tenantId])
  @@map("products")
}

// ═══════════════════════════════════════════════════════════════════════
// CATEGORY — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  deletedAt   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  products Product[]

  @@unique([tenantId, name])
  @@map("categories")
}

// ═══════════════════════════════════════════════════════════════════════
// SUPPLIER — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?         @db.Text
  deletedAt      DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, name])
  @@map("suppliers")
}

// ═══════════════════════════════════════════════════════════════════════
// STOCK TRANSACTION — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

model StockTransaction {
  id          String          @id @default(uuid())
  type        TransactionType
  quantity    Int
  referenceId String?
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   TenantUser @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([productId])
  @@map("stock_transactions")
}

// ═══════════════════════════════════════════════════════════════════════
// PURCHASE ORDER — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String
  totalPrice  Decimal             @db.Decimal(12, 2)
  status      PurchaseOrderStatus @default(PENDING)
  notes       String?             @db.Text
  createdAt   DateTime            @default(now())
  receivedAt  DateTime?
  deletedAt   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  userId     String
  user       TenantUser          @relation(fields: [userId], references: [id])
  items      PurchaseOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([supplierId])
  @@index([userId])
  @@index([tenantId, createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// ═══════════════════════════════════════════════════════════════════════
// SALES ORDER — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

enum SalesOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(uuid())
  orderNumber String
  customerId  String?
  totalPrice  Decimal          @db.Decimal(12, 2)
  totalCogs   Decimal          @default(0) @db.Decimal(12, 2)
  totalProfit Decimal          @default(0) @db.Decimal(12, 2)
  status      SalesOrderStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  userId  String
  user    TenantUser  @relation(fields: [userId], references: [id])
  items   OrderItem[]
  returns SalesReturn[]

  @@unique([tenantId, orderNumber])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([userId])
  @@index([customerId])
  @@map("sales_orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  quantity         Int
  returnedQuantity Int     @default(0)
  unitPrice        Decimal @db.Decimal(12, 2)
  cogs             Decimal @default(0) @db.Decimal(12, 2)
  profitMargin     Decimal @default(0) @db.Decimal(12, 2)

  orderId String
  order   SalesOrder @relation(fields: [orderId], references: [id])

  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  returnItems SalesReturnItem[]

  @@map("order_items")
}

// ═══════════════════════════════════════════════════════════════════════
// SALES RETURN — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

enum ReturnStatus {
  PENDING
  COMPLETED
  REJECTED
}

model SalesReturn {
  id           String       @id @default(uuid())
  returnNumber String
  reason       String?      @db.Text
  totalRefund  Decimal      @default(0) @db.Decimal(12, 2)
  status       ReturnStatus @default(PENDING)
  createdAt    DateTime     @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])

  userId String
  user   TenantUser @relation(fields: [userId], references: [id])

  items SalesReturnItem[]

  @@unique([tenantId, returnNumber])
  @@index([returnNumber])
  @@index([salesOrderId])
  @@map("sales_returns")
}

model SalesReturnItem {
  id           String  @id @default(uuid())
  quantity     Int
  refundAmount Decimal @db.Decimal(12, 2)

  returnId String
  return   SalesReturn @relation(fields: [returnId], references: [id])

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("sales_return_items")
}

// ═══════════════════════════════════════════════════════════════════════
// ACTIVITY LOG — Terikat ke tenant
// ═══════════════════════════════════════════════════════════════════════

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

model ActivityLog {
  id        String         @id @default(uuid())
  userId    String
  user      TenantUser     @relation(fields: [userId], references: [id])
  action    ActivityAction
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime       @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@index([tenantId, entity, createdAt])
  @@map("activity_logs")
}

// ═══════════════════════════════════════════════════════════════════════
// REFRESH TOKEN — Terikat ke tenant user
// ═══════════════════════════════════════════════════════════════════════

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      TenantUser @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
