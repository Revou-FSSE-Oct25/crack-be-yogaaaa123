datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STAFF
}

model User {
  id             String             @id @default(uuid())
  username       String             @unique
  email          String             @unique
  passwordHash   String
  role           Role               @default(STAFF)
  createdAt      DateTime           @default(now())
  deletedAt      DateTime?
  transactions   StockTransaction[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  returns        SalesReturn[]
  activityLogs   ActivityLog[]
  refreshTokens  RefreshToken[]

  @@map("users")
}
model Product {
  id            String    @id @default(uuid())
  sku           String    @unique
  name          String
  description   String?   @db.Text
  imageUrl      String?
  price         Decimal   @db.Decimal(12, 2)
  averageCost   Decimal   @default(0) @db.Decimal(12, 2)
  stockQuantity Int       @default(0)
  reorderLevel  Int       @default(10)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  transactions       StockTransaction[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([sku])
  @@index([name])
  @@map("products")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  deletedAt   DateTime?
  products    Product[]

  @@map("categories")
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?         @db.Text
  deletedAt      DateTime?
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// 3. Ledger Transaksi Stok
enum TransactionType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

model StockTransaction {
  id          String          @id @default(uuid())
  type        TransactionType
  quantity    Int
  referenceId String? // Bisa diisi Order Number
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([productId])
  @@map("stock_transactions")
}

// 4. Pembelian dari Supplier
enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String              @unique
  totalPrice  Decimal             @db.Decimal(12, 2)
  status      PurchaseOrderStatus @default(PENDING)
  notes       String?             @db.Text
  createdAt   DateTime            @default(now())
  receivedAt  DateTime?
  deletedAt   DateTime?

  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  items      PurchaseOrderItem[]

  @@index([orderNumber])
  @@index([createdAt])
  @@index([supplierId])
  @@index([userId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// 5. Penjualan ke Customer
enum SalesOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(uuid())
  orderNumber String           @unique
  customerId  String? // ID customer (bisa nomor/timestamp, tanpa nama)
  totalPrice  Decimal          @db.Decimal(12, 2)
  totalCogs   Decimal          @default(0) @db.Decimal(12, 2)
  totalProfit Decimal          @default(0) @db.Decimal(12, 2)
  status      SalesOrderStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?

  userId  String
  user    User          @relation(fields: [userId], references: [id])
  items   OrderItem[]
  returns SalesReturn[]

  @@index([orderNumber])
  @@index([createdAt])
  @@index([userId])
  @@index([customerId])
  @@map("sales_orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  quantity         Int
  returnedQuantity Int     @default(0)
  unitPrice        Decimal @db.Decimal(12, 2)
  cogs             Decimal @default(0) @db.Decimal(12, 2)
  profitMargin     Decimal @default(0) @db.Decimal(12, 2)

  orderId String
  order   SalesOrder @relation(fields: [orderId], references: [id])

  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  returnItems SalesReturnItem[]

  @@map("order_items")
}

// 6. Retur Penjualan
enum ReturnStatus {
  PENDING
  COMPLETED
  REJECTED
}

model SalesReturn {
  id           String       @id @default(uuid())
  returnNumber String       @unique
  reason       String?      @db.Text
  totalRefund  Decimal      @default(0) @db.Decimal(12, 2)
  status       ReturnStatus @default(PENDING)
  createdAt    DateTime     @default(now())

  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  items SalesReturnItem[]

  @@index([returnNumber])
  @@index([salesOrderId])
  @@map("sales_returns")
}

model SalesReturnItem {
  id           String  @id @default(uuid())
  quantity     Int
  refundAmount Decimal @db.Decimal(12, 2)

  returnId String
  return   SalesReturn @relation(fields: [returnId], references: [id])

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("sales_return_items")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

model ActivityLog {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  action    ActivityAction
  entity    String         // e.g. "Product", "SalesOrder", "User"
  entityId  String?        // ID dari entitas yang di-log
  metadata  Json?          // Detail tambahan (JSON)
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
